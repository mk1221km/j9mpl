{
  "String": [
    {
      "domain": "SQL_INJECTION",
      "payload": {
        "valid": [
          "normal_string_test",
          "cpu_usage",
          "standard_channel"
        ],
        "counter": [
          {
            "value": "' OR '1'='1",
            "expected": "java.sql.SQLException"
          },
          {
            "value": "'; DROP TABLE system_metrics; --",
            "expected": "java.sql.SQLException"
          },
          {
            "value": "' UNION SELECT null, null, null --",
            "expected": "java.sql.SQLException"
          }
        ]
      }
    },
    {
      "domain": "PATH_TRAVERSAL",
      "payload": {
        "valid": [
          "generated/metrics_test.db",
          "metrics.db",
          "routing.db"
        ],
        "counter": [
          {
            "value": "/etc/passwd",
            "expected": "java.io.IOException"
          },
          {
            "value": "../../../etc/passwd",
            "expected": "java.io.IOException"
          },
          {
            "value": "C:\\Windows\\win.ini",
            "expected": "java.io.IOException"
          }
        ]
      }
    },
    {
      "domain": "EMPTY_NULL",
      "payload": {
        "valid": [
          "normal_string",
          "cpu_usage"
        ],
        "counter": [
          {
            "value": "",
            "expected": "java.lang.IllegalArgumentException"
          },
          {
            "value": "null",
            "expected": "java.lang.IllegalArgumentException"
          },
          {
            "value": "   ",
            "expected": "java.lang.IllegalArgumentException"
          }
        ]
      }
    }
  ],
  "double": [
    {
      "domain": "NUMERIC_OVERFLOW_DOUBLE",
      "payload": {
        "valid": [
          "0",
          "1.5",
          "-45.2",
          "100.0",
          "1.7976931348623157e+308",
          "-1.7976931348623157e+308"
        ],
        "counter": [
          {
            "value": "1.7976931348623159e+308",
            "expected": "java.lang.NumberFormatException"
          },
          {
            "value": "-1.7976931348623159e+308",
            "expected": "java.lang.NumberFormatException"
          },
          {
            "value": "NaN",
            "expected": "java.lang.NumberFormatException"
          },
          {
            "value": "Infinity",
            "expected": "java.lang.NumberFormatException"
          },
          {
            "value": "-Infinity",
            "expected": "java.lang.NumberFormatException"
          }
        ]
      }
    }
  ],
  "int": [
    {
      "domain": "NUMERIC_OVERFLOW_INT",
      "payload": {
        "valid": [
          "0",
          "100",
          "-50",
          "999",
          "2147483647",
          "-2147483648"
        ],
        "counter": [
          {
            "value": "2147483648",
            "expected": "java.lang.NumberFormatException"
          },
          {
            "value": "-2147483649",
            "expected": "java.lang.NumberFormatException"
          }
        ]
      }
    }
  ]
}